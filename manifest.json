{
  "name": "__MSG_extensionName__",
  "short_name": "bookmarkdupes",
  "description": "__MSG_extensionDescription__",
  "author": "Martin Väth",
  "version": "6.7",
  "manifest_version": 3,
  "homepage_url": "https://github.com/vaeth/bookmarkdupes/",
  "default_locale": "en",

  "permissions": [
    "bookmarks",
    "storage"
  ],

  "background": {
    "scripts": [
      "background.js"
    ]
  },

  "action": {
    "default_icon": {
      "16": "data/icons/48.svg",
      "19": "data/icons/48.svg",
      "20": "data/icons/48.svg",
      "24": "data/icons/48.svg",
      "30": "data/icons/48.svg",
      "32": "data/icons/48.svg",
      "38": "data/icons/48.svg",
      "48": "data/icons/48.svg",
      "64": "data/icons/48.svg",
      "96": "data/icons/48.svg",
      "128": "data/icons/48.svg"
    }
  },

  "options_ui": {
    "page": "data/options/index.html"
  },

  "icons": {
    "16": "data/icons/48.svg",
    "19": "data/icons/48.svg",
    "20": "data/icons/48.svg",
    "24": "data/icons/48.svg",
    "30": "data/icons/48.svg",
    "32": "data/icons/48.svg",
    "38": "data/icons/48.svg",
    "48": "data/icons/48.svg",
    "64": "data/icons/48.svg",
    "96": "data/icons/48.svg",
    "128": "data/icons/48.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "bookmarkdupes@martin-vaeth.org"
    }
  }
}
